rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config
    // Document ID: game
    // Fields:
    //   - roadColor: string (optional, hex color)
    //   - skyColor: string (optional, hex color)
    //   - characterModels: map (optional, contains default, robot, ninja as strings)
    //   - obstacleModels: map (optional, contains train, barrier, coin as strings)
    //   - guardModel: string (optional, GLB URL)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "alyinel9@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidHexColor(color) {
      return color is string && color.matches("^#[0-9a-fA-F]{3,8}$");
    }

    function isValidUrl(url) {
      return url == "" || url is string;
    }

    function isValidGameConfig(data) {
      return (!('roadColor' in data) || isValidHexColor(data.roadColor)) &&
             (!('skyColor' in data) || isValidHexColor(data.skyColor)) &&
             (!('guardModel' in data) || isValidUrl(data.guardModel)) &&
             (!('characterModels' in data) || data.characterModels is map) &&
             (!('obstacleModels' in data) || data.obstacleModels is map) &&
             (!('powerupModels' in data) || data.powerupModels is map) &&
             (!('environmentModels' in data) || data.environmentModels is map) &&
             (!('gameSettings' in data) || data.gameSettings is map) &&
             (!('lightSettings' in data) || data.lightSettings is map) &&
             (!('cameraSettings' in data) || data.cameraSettings is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /config/game {
      // Anyone can read the game config to load the game
      allow read: if true;
      
      // Only the admin can create or update the config
      allow create: if isAdmin() && isValidGameConfig(request.resource.data);
      allow update: if isAdmin() && isValidGameConfig(request.resource.data);
      allow delete: if false; // Config should not be deleted
    }
  }
}
