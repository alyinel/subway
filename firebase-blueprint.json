{
  "entities": {
    "GameConfig": {
      "title": "Game Configuration",
      "description": "Global configuration for the game, customizable via the admin panel.",
      "type": "object",
      "properties": {
        "roadColor": {
          "type": "string",
          "description": "Hex color code for the road."
        },
        "skyColor": {
          "type": "string",
          "description": "Hex color code for the sky."
        },
        "characterModels": {
          "type": "object",
          "description": "URLs for character GLB models.",
          "properties": {
            "default": { "type": "string" },
            "robot": { "type": "string" },
            "ninja": { "type": "string" }
          }
        },
        "obstacleModels": {
          "type": "object",
          "description": "URLs for obstacle GLB models.",
          "properties": {
            "train": { "type": "string" },
            "barrier": { "type": "string" },
            "coin": { "type": "string" },
            "car": { "type": "string" },
            "sign": { "type": "string" }
          }
        },
        "powerupModels": {
          "type": "object",
          "description": "URLs for powerup GLB models.",
          "properties": {
            "invincible": { "type": "string" },
            "hoverboard": { "type": "string" },
            "fly": { "type": "string" }
          }
        },
        "environmentModels": {
          "type": "object",
          "description": "URLs for environment GLB models.",
          "properties": {
            "buildingA": { "type": "string" },
            "buildingB": { "type": "string" },
            "buildingC": { "type": "string" }
          }
        },
        "guardModel": {
          "type": "string",
          "description": "URL for the guard GLB model."
        },
        "gameSettings": {
          "type": "object",
          "description": "Game mechanics settings.",
          "properties": {
            "baseSpeed": { "type": "number" },
            "speedIncrement": { "type": "number" },
            "maxSpeed": { "type": "number" },
            "coinValue": { "type": "number" }
          }
        },
        "lightSettings": {
          "type": "object",
          "description": "Lighting settings.",
          "properties": {
            "ambientIntensity": { "type": "number" },
            "directionalIntensity": { "type": "number" },
            "directionalColor": { "type": "string" }
          }
        },
        "cameraSettings": {
          "type": "object",
          "description": "Camera settings.",
          "properties": {
            "fov": { "type": "number" },
            "yOffset": { "type": "number" },
            "zOffset": { "type": "number" }
          }
        }
      }
    }
  },
  "firestore": {
    "/config/game": {
      "schema": "GameConfig",
      "description": "The single document storing the game's global configuration."
    }
  }
}
